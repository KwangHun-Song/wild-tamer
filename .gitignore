.claude/
.omc/
.mcp.json

# ===== OS =====
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Unity Editor temp files
Assets/Editor/Temp.meta

# Screenshots
/[Aa]ssets/[Ss]creenshots/
